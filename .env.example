# ─────────────────────────────────────────────────────────────────────────────
# InsightFlow configuration.
#
# Copy this file to `.env` (which is git-ignored) and uncomment what you need.
# EVERY value here is OPTIONAL — the app runs with sensible defaults and zero setup.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Where experiments/assignments/observations are stored.
# Default: a local SQLite file (no install needed).
DATABASE_URL=sqlite:///./insightflow.db
# For PostgreSQL (e.g. via infra/docker-compose.yml), use instead:
# DATABASE_URL=postgresql+psycopg://insightflow:insightflow@localhost:5432/insightflow

# Log every SQL statement to the console (verbose; handy when debugging).
SQL_ECHO=false

# ── Cache ───────────────────────────────────────────────────────────────────
# Speeds up repeat /results, /report, /charts loads. If unset (or unreachable),
# the app falls back to an in-process memory cache automatically — nothing breaks.
# REDIS_URL=redis://localhost:6379/0

# ── LLM for report narratives (all FREE options) ────────────────────────────
# Which backend generates the plain-English experiment summary.
#   template  (default) — deterministic, no key, always works
#   groq                — free Llama 3.3 70B via Groq's API (needs GROQ_API_KEY)
#   ollama              — a fully local model via the Ollama daemon (no key)
# INSIGHTFLOW_LLM=template

# --- If INSIGHTFLOW_LLM=groq: get a free key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_free_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- If INSIGHTFLOW_LLM=ollama: install from https://ollama.com and `ollama pull llama3.2`
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434
