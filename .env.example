# Copy to `.env` and adjust. All values are optional — sensible defaults are built in.

# Storage. Defaults to a local SQLite file if unset.
# For PostgreSQL (via infra/docker-compose.yml):
# DATABASE_URL=postgresql+psycopg://insightflow:insightflow@localhost:5432/insightflow
DATABASE_URL=sqlite:///./insightflow.db

# Set to true to log every SQL statement (verbose; useful when debugging).
SQL_ECHO=false
