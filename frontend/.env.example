# Frontend build-time config. Copy to `.env.local` for local overrides (git-ignored).

# Base URL of the deployed API, with NO trailing slash.
# Leave this UNSET for local development, where requests fall back to the "/api"
# Vite proxy. Set it in Vercel (Project Settings > Environment Variables) to your
# Render API URL, for example:
# VITE_API_URL=https://insightflow-api.onrender.com
